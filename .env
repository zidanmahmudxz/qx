#  Signal Pro v5 — .env Configuration
# ══════════════════════════════════════

PORT=3000

# Quotex Realtime API
API_HOST=api.gochart.in
API_PATH=/api/v1/market/tick-stream

# AI Keys
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot Token (Chat IDs managed in software)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Auth
JWT_SECRET=signalpro_v5_secret_2024

# Admin credentials
ADMIN_USER=admin
ADMIN_PASS=admin123

# DB retention
CANDLE_DAYS=30
SIGNAL_DAYS=90
